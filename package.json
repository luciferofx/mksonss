{
  "name": "corporategiftsemporium-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon server.js",
    "build": "npx ncc build server.js -o dist && copyfiles .env dist/ && copyfiles -u 1 \"../assets/**/*\" dist/ && node -e \"require('fs').mkdirSync('dist/css', {recursive: true})\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.1.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.4",
    "copyfiles": "^2.4.1",
    "nodemon": "^3.0.3"
  }
}
